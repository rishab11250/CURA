# Environment variables definition

# The port the app runs on
PORT=5000

# MongoDB URI connection string
MONGO_URI=mongodb://localhost:27017/drug_insights

# Bytez API Key (get from bytez.com)
BYTEZ_API_KEY=your_bytez_api_key

# OpenFDA API Config
OPENFDA_API_URL=https://api.fda.gov/drug
OPENFDA_API_KEY=your_fda_api_key

# JWT Authentication
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=30d

# Google Places API (for hospital/clinic finder)
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Any other environment variables
